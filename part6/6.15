import { render, screen, cleanup } from '@testing-library/react'
import { describe, test, expect, vi } from 'vitest'
import AnecdoteList from './AnecdoteList'
import useAnecdoteStore, { useAnecdotes, useAnecdoteActions } from '../store'
import anecdoteService from '../services/anecdotes'
import userEvent from '@testing-library/user-event'

vi.mock('../services/anecdotes')

test.afterEach(() => {
	cleanup()
	vi.clearAllMocks()
})

test.beforeEach(() => {
	useAnecdoteStore.setState({ anecdotes: [], filter: '' })
})

describe('AnecdoteList', () => {
	test('anecdotes are displayed sorted by votes', () => {
		const anecdotes = [
			{ id: '1', content: 'Anecdote with mid votes', votes: 5 },
			{ id: '2', content: 'Anecdote with most votes', votes: 10 },
			{ id: '3', content: 'Anecdote with least votes', votes: 2 },
		]
		useAnecdoteStore.setState({ anecdotes: anecdotes, filter: '' })

		render(<AnecdoteList />)

		const allItems = screen.getAllByText(/Anecdote with/i)

		expect(allItems[0].textContent).toContain('most votes')
		expect(allItems[1].textContent).toContain('mid votes')
		expect(allItems[2].textContent).toContain('least votes')
	})

	test('anecdotes matching the filter are displayed', () => {
		const anecdotes = [
			{ id: '1', content: 'React is a library', votes: 0 },
			{ id: '2', content: 'Redux is for state', votes: 0 },
			{ id: '3', content: 'Zustand is simpler', votes: 0 },
		]

		useAnecdoteStore.setState({ anecdotes: anecdotes, filter: 'state' })

		render(<AnecdoteList />)

		const matchingItem = screen.getByText("Redux is for state")
		expect(matchingItem).toBeDefined()

		const hiddenItem1 = screen.queryByText("React is a library")
		const hiddenItem2 = screen.queryByText("Zustand is simpler")

		expect(hiddenItem1).toBeNull()
		expect(hiddenItem2).toBeNull()
	})

	test('voting increases the number of votes for an anecdote', async () => {
		const anecdotes = [
			{ id: '1', content: 'React is a library', votes: 0 },
		]

		useAnecdoteStore.setState({ anecdotes: anecdotes, filter: '' })

		render(<AnecdoteList />)

		const user = userEvent.setup()

		anecdoteService.update.mockResolvedValue({ ...anecdotes[0], votes: 1 })

		expect(screen.getByText("has 0")).toBeDefined()

		const voteButton = screen.getByRole('button', { name: "vote" })
		await user.click(voteButton)

		expect(anecdoteService.update).toHaveBeenCalledWith('1', { ...anecdotes[0], votes: 1 })

		const updatedVotes = await screen.findByText("has 1")
		expect(updatedVotes).toBeDefined()
	})
})
